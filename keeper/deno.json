{
  "$schema": "https://deno.land/x/deno/cli/schemas/config-file.v1.json",
  "name": "@solana-boilerplate/keeper",
  "version": "0.1.0",
  "exports": "./src/main.ts",
  "tasks": {
    "dev": "deno run -A --unstable-sloppy-imports src/main.ts",
    "start": "deno run -A --unstable-sloppy-imports src/main.ts start",
    "check": "deno check --unstable-sloppy-imports src/main.ts",
    "compile": "deno compile -A --unstable-sloppy-imports --output keeper-bot src/main.ts"
  },
  "imports": {
    "@solana/web3.js": "npm:@solana/web3.js@1.98.0",
    "@solana/spl-token": "npm:@solana/spl-token@0.4.14",
    "@coral-xyz/anchor": "npm:@coral-xyz/anchor@0.32.1",
    "bs58": "npm:bs58@^6.0.0",
    "bn.js": "npm:bn.js@5.2.1",
    "events": "node:events",
    "buffer": "node:buffer",
    "@std/cli": "jsr:@std/cli@1.0.0",
    "@std/fmt": "jsr:@std/fmt@1.0.0",
    "@std/dotenv": "jsr:@std/dotenv@0.225.0"
  },
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "lib": ["deno.window", "deno.ns", "esnext"]
  },
  "nodeModulesDir": "auto"
}
